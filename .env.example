# --- Required ---

# PostgreSQL connection string used by the app and by drizzle migrations.
# Example: postgres://timetable:strongpassword@localhost:5432/timetable
DATABASE_URL=

# Long, random secret used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Public URL the app is served from (no trailing slash).
# Used to build the Google OAuth callback URL.
APP_URL=https://timetable.seatofwisdomacademy.com

# --- Required for Google login (omit to disable Google sign-in) ---

# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URI must be: ${APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional ---

# Set to "production" when running with `npm run start`. Enables secure cookies.
NODE_ENV=production

# Port the Node server listens on. Nginx proxies to this port.
PORT=5000
